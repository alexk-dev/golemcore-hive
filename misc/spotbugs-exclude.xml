<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Class name="~me\.golemcore\.hive\..*" />
    </Match>

    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Not>
            <Class name="~me\.golemcore\.hive\.domain\.model\..*" />
        </Not>
    </Match>

    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
        <Or>
            <Class name="~me\.golemcore\.hive\.adapter\..*" />
            <Class name="~me\.golemcore\.hive\.domain\.service\..*" />
        </Or>
    </Match>

    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION" />
        <Or>
            <Class name="~me\.golemcore\.hive\.adapter\..*" />
            <Class name="~me\.golemcore\.hive\.domain\.service\..*" />
        </Or>
    </Match>

    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION" />
        <Or>
            <Class name="~me\.golemcore\.hive\.adapter\..*" />
            <Class name="~me\.golemcore\.hive\.domain\.service\..*" />
        </Or>
    </Match>
</FindBugsFilter>
